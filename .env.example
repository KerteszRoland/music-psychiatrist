# AI provider: openai | anthropic | google | openai-compatible
AI_PROVIDER=openai

# Model id for your provider (examples below)
# openai:     gpt-4o, gpt-4o-mini
# anthropic:  claude-sonnet-4-20250514
# google:     gemini-2.0-flash
# openai-compatible: whatever your endpoint supports (e.g. deepseek-chat, llama-3)
AI_MODEL=gpt-4o-mini

# Provider API keys (set the one matching AI_PROVIDER)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# For OpenAI-compatible gateways (OpenRouter, Groq, Ollama, etc.)
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=https://openrouter.ai/api/v1

# Vercel Blob (required on Vercel for storing analyses; local dev uses .data/ folder)
BLOB_READ_WRITE_TOKEN=
